---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const entries = (await getCollection("events")).sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title="사건 | Fantasy Library">
  <div class="section-header">
    <h1>사건</h1>
    <span class="section-count">{entries.length}개</span>
  </div>
  <div class="list">
    {entries.map((entry) => (
      <a class="card" href={`${base}/events/${entry.slug}`}>
        <h3>{entry.data.name}</h3>
        <p>{entry.data.summary}</p>
        <p class="meta">{entry.data.id}{entry.data.date_label ? " · " + entry.data.date_label : ""}</p>
      </a>
    ))}
  </div>
</BaseLayout>
