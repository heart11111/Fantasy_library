---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const entries = (await getCollection("events")).sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title="사건 | Fantasy Library">
  <h1>사건</h1>
  <div class="list">
    {entries.map((entry) => (
      <a class="card" href={`${base}/events/${entry.slug}`}>
        <h2>{entry.data.name}</h2>
        <p>{entry.data.summary}</p>
        <p class="meta">{entry.data.id} · {entry.data.date_label}</p>
      </a>
    ))}
  </div>
</BaseLayout>
