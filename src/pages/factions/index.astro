---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const entries = (await getCollection("factions")).sort((a, b) => a.data.name.localeCompare(b.data.name, "ko"));
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title="팩션 | Fantasy Library">
  <div class="section-header">
    <h1>팩션</h1>
    <span class="section-count">{entries.length}개</span>
  </div>
  <div class="list">
    {entries.map((entry) => (
      <a class="card" href={`${base}/factions/${entry.slug}`}>
        <h3>{entry.data.name}</h3>
        <p>{entry.data.summary}</p>
        <p class="meta">{entry.data.id} · 확신도 {entry.data.confidence}</p>
      </a>
    ))}
  </div>
</BaseLayout>
