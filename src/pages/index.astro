---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const [sessions, characters, locations, factions, events] = await Promise.all([
  getCollection("sessions"),
  getCollection("characters"),
  getCollection("locations"),
  getCollection("factions"),
  getCollection("events")
]);

const recentSessions = sessions
  .sort((a, b) => (a.data.id > b.data.id ? -1 : 1))
  .slice(0, 6);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const cats = [
  { href: `${base}/sessions`,    count: sessions.length,    name: "세션",   desc: "RP 로그에서 정리한 세션 기록" },
  { href: `${base}/characters`,  count: characters.length,  name: "캐릭터", desc: "등장인물 초벌 문서" },
  { href: `${base}/locations`,   count: locations.length,   name: "지역",   desc: "세계관 지역 문서" },
  { href: `${base}/factions`,    count: factions.length,    name: "팩션",   desc: "세력 및 조직 문서" },
  { href: `${base}/events`,      count: events.length,      name: "사건",   desc: "시간순 정리 사건 문서" },
];
---

<BaseLayout>
  <section class="hero">
    <p class="eyebrow">Public RP Codex</p>
    <h1>Fantasy Library</h1>
    <p class="lead">
      공개된 RP 로그와 세션 기록을 바탕으로 정리한 세계관 위키입니다.
      확정 정보와 추정 정보를 분리하고, 모든 항목은 원문 로그 출처를 남깁니다.
    </p>
  </section>

  <section class="cat-grid" aria-label="카테고리">
    {cats.map((c) => (
      <a class="card cat-card" href={c.href}>
        <span class="cat-count">{c.count}</span>
        <h2>{c.name}</h2>
        <p>{c.desc}</p>
      </a>
    ))}
  </section>

  <section>
    <h2>최근 세션</h2>
    <div class="list">
      {recentSessions.map((entry) => (
        <a class="card" href={`${base}/sessions/${entry.slug}`}>
          <h3>{entry.data.name}</h3>
          <p>{entry.data.summary}</p>
          <p class="meta">{entry.data.id}{entry.data.tags?.filter((t: string) => t !== "session").length ? " · " + entry.data.tags.filter((t: string) => t !== "session").join(", ") : ""}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
