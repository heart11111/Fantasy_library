---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const [sessions, characters, locations, factions, events] = await Promise.all([
  getCollection("sessions"),
  getCollection("characters"),
  getCollection("locations"),
  getCollection("factions"),
  getCollection("events")
]);

const recentSessions = sessions
  .sort((a, b) => (a.data.id > b.data.id ? -1 : 1))
  .slice(0, 6);
---

<BaseLayout>
  <section class="hero">
    <p class="eyebrow">Public RP Codex</p>
    <h1>Fantasy Library</h1>
    <p class="lead">
      공개된 RP 로그와 세션 기록을 바탕으로 정리한 세계관 위키입니다. 확정 정보와 추정 정보를 분리하고,
      모든 항목은 원문 로그 출처를 남깁니다.
    </p>
  </section>

  <section class="grid" aria-label="카테고리">
    <a class="card" href="/sessions"><h2>세션</h2><p>{sessions.length}개 세션 정리</p></a>
    <a class="card" href="/characters"><h2>캐릭터</h2><p>{characters.length}개 초벌 문서</p></a>
    <a class="card" href="/locations"><h2>지역</h2><p>{locations.length}개 초벌 문서</p></a>
    <a class="card" href="/factions"><h2>팩션</h2><p>{factions.length}개 초벌 문서</p></a>
    <a class="card" href="/events"><h2>사건</h2><p>{events.length}개 사건 문서</p></a>
  </section>

  <section>
    <h2>최근 세션</h2>
    <div class="list">
      {recentSessions.map((entry) => (
        <a class="card" href={`/sessions/${entry.slug}`}>
          <h3>{entry.data.name}</h3>
          <p>{entry.data.summary}</p>
          <p class="meta">{entry.data.id} · {entry.data.tags?.join(", ")}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
