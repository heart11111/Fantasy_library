---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const entries = (await getCollection("sessions")).sort((a, b) => a.data.id.localeCompare(b.data.id));
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title="세션 | Fantasy Library">
  <h1>세션</h1>
  <div class="list">
    {entries.map((entry) => (
      <a class="card" href={`${base}/sessions/${entry.slug}`}>
        <h2>{entry.data.name}</h2>
        <p>{entry.data.summary}</p>
        <p class="meta">{entry.data.id} · {entry.data.canon_status} · {entry.data.confidence}</p>
      </a>
    ))}
  </div>
</BaseLayout>
